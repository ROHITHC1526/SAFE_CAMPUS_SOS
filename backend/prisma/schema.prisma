generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  STUDENT
  SECURITY
  ADMIN
}

enum IncidentStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  ON_THE_WAY
  REACHED
  RESOLVED
  CANCELLED
  FALSE_ALARM
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmergencyCategory {
  MEDICAL
  FIRE
  HARASSMENT
  RAGGING
  ACCIDENT
  THEFT
  VIOLENCE
  OTHER
}

enum ResponderStatus {
  AVAILABLE
  BUSY
  OFF_DUTY
  ON_MISSION
}

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  RINGING
  ONGOING
  ENDED
  MISSED
  REJECTED
}

enum NotificationType {
  SOS_ALERT
  ASSIGNMENT
  STATUS_UPDATE
  CHAT_MESSAGE
  SYSTEM
  REMINDER
}

enum ContactRelation {
  PARENT
  SIBLING
  FRIEND
  FACULTY
  OTHER
}

enum MediaType {
  PHOTO
  VIDEO
  AUDIO
  DOCUMENT
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  role              UserRole
  isActive          Boolean   @default(true)
  isVerified        Boolean   @default(false)
  lastLogin         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  emergencyContacts EmergencyContact[]
  medicalProfile    MedicalProfile?
  incidents         Incident[]         @relation("StudentIncidents")
  assignments       ResponderAssignment[] @relation("ResponderAssignments")
  securityGuard     SecurityGuard?
  liveLocations     LiveLocation[]
  sentMessages      ChatMessage[]      @relation("SentMessages")
  notifications     Notification[]
  activityLogs      ActivityLog[]
  deviceTokens      DeviceToken[]
  mediaEvidence     MediaEvidence[]
  auditLogs         AuditLog[]

  @@index([role])
}

model EmergencyContact {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  name      String
  phone     String
  email     String?
  relation  ContactRelation
  isPrimary Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MedicalProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique @db.ObjectId
  bloodGroup     String?
  allergies      String[]
  diseases       String[]
  medications    String[]
  emergencyNotes String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Incident {
  id              String            @id @default(auto()) @map("_id") @db.ObjectId
  studentId       String            @db.ObjectId
  category        EmergencyCategory
  severity        IncidentSeverity  @default(MEDIUM)
  status          IncidentStatus    @default(PENDING)
  title           String
  description     String?
  latitude        Float
  longitude       Float
  address         String?
  aiThreatScore   Float?
  isFakeSOS       Boolean           @default(false)
  resolvedAt      DateTime?
  responseTime    Int?              // seconds
  summary         String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  student         User              @relation("StudentIncidents", fields: [studentId], references: [id])
  assignments     ResponderAssignment[]
  chatMessages    ChatMessage[]
  timeline        IncidentTimeline[]
  callLogs        CallLog[]
  mediaEvidence   MediaEvidence[]
  incidentReport  IncidentReport?
  liveLocations   LiveLocation[]

  @@index([studentId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ResponderAssignment {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  incidentId   String   @db.ObjectId
  responderId  String   @db.ObjectId
  assignedAt   DateTime @default(now())
  acceptedAt   DateTime?
  arrivedAt    DateTime?
  completedAt  DateTime?
  distance     Float?   // km
  eta          Int?     // minutes
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  incident  Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  responder User     @relation("ResponderAssignments", fields: [responderId], references: [id])

  @@index([incidentId])
  @@index([responderId])
}

model SecurityGuard {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @unique @db.ObjectId
  badgeNumber    String         @unique
  status         ResponderStatus @default(AVAILABLE)
  currentLat     Float?
  currentLng     Float?
  specialization String[]
  shift          String?
  zone           String?
  rating         Float          @default(5.0)
  totalResolved  Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model LiveLocation {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  incidentId String?   @db.ObjectId
  latitude   Float
  longitude  Float
  accuracy   Float?
  speed      Float?
  heading    Float?
  isActive   Boolean   @default(true)
  timestamp  DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  incident Incident? @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([incidentId])
  @@index([timestamp])
}

model ChatMessage {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  incidentId String   @db.ObjectId
  senderId   String   @db.ObjectId
  content    String
  type       String   @default("text") // text, image, file, voice
  fileUrl    String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([incidentId])
  @@index([senderId])
}

model IncidentReport {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  incidentId    String   @unique @db.ObjectId
  reportContent String
  pdfUrl        String?
  generatedBy   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model IncidentTimeline {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  incidentId String   @db.ObjectId
  event      String
  details    String?
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
  @@index([timestamp])
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model DeviceToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  platform  String   // web, android, ios
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HeatmapData {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  latitude  Float
  longitude Float
  intensity Float             @default(1.0)
  category  EmergencyCategory
  buildingId String?          @db.ObjectId
  hour      Int?
  dayOfWeek Int?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  building CampusBuilding? @relation(fields: [buildingId], references: [id])

  @@index([category])
  @@index([createdAt])
}

model CampusBuilding {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String   @unique
  latitude    Float
  longitude   Float
  type        String   // academic, hostel, admin, sports, canteen
  floor       Int?
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  heatmapData HeatmapData[]
  safeZones   SafeZone[]
}

model SafeZone {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  latitude    Float
  longitude   Float
  radius      Float    // meters
  buildingId  String?  @db.ObjectId
  description String?
  hasCamera   Boolean  @default(false)
  hasGuard    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building CampusBuilding? @relation(fields: [buildingId], references: [id])

  @@index([buildingId])
}

model EmergencyType {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique
  icon        String?
  color       String?
  priority    Int      @default(5)
  description String?
  guidelines  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CallLog {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  incidentId String     @db.ObjectId
  callerId   String
  receiverId String
  type       CallType
  status     CallStatus
  startedAt  DateTime?
  endedAt    DateTime?
  duration   Int?       // seconds
  recordingUrl String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

model MediaEvidence {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  incidentId String    @db.ObjectId
  uploadedBy String    @db.ObjectId
  type       MediaType
  url        String
  thumbnail  String?
  fileName   String?
  fileSize   Int?
  mimeType   String?
  caption    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  uploader User     @relation(fields: [uploadedBy], references: [id])

  @@index([incidentId])
}

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?  @db.ObjectId
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([entity])
  @@index([createdAt])
}

model Settings {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  category  String   @default("general")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}
